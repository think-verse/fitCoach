rules_version = '2';

// FitCoach Firestore security rules.
// Server code uses the Admin SDK (bypasses these rules); these protect direct
// client access. Principle: a signed-in user touches ONLY their own data.
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns everything under users/{uid}, including subcollections.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public pricing is world-readable; only the server (Admin SDK) writes it.
    match /config/pricing {
      allow read: if true;
      allow write: if false;
    }

    // Payments are server-only (written via Admin SDK in the PayPal routes).
    match /payments/{id} {
      allow read, write: if false;
    }
  }
}
