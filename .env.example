# =============================================================================
# AesthetixAI environment — Firebase backend + Anthropic AI.
# Copy to .env.local and fill in. NEVER commit .env.local.
# =============================================================================

# --- Firebase (client / public — safe to expose) ---
# Firebase console > Project settings > General > Your apps > SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server only — service account JSON fields) ---
# Firebase console > Project settings > Service accounts > Generate new private key.
# Paste the private key with literal \n escapes preserved, wrapped in quotes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- AI provider (Anthropic Claude — hybrid model tiers) ---
# https://console.anthropic.com/
#   VISION_MODEL — photo body analysis + weekly photo comparison (quality-critical)
#   TEXT_MODEL   — workout / diet / coach chat (cheaper, text-only)
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_TEXT_MODEL=claude-haiku-4-5
# Max concurrent AI calls (queue). 6th+ waits for a free slot.
AI_MAX_CONCURRENCY=5
# Optional: max in-flight AI calls per single user (fairness). 0 = no per-user cap.
AI_MAX_PER_USER=2

# --- Admin panel (static credentials — NOT Firebase auth) ---
# The single admin signs in at /admin/login with exactly these.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Random long string used to sign the admin session cookie.
ADMIN_SESSION_SECRET=

# --- App ---
# Public base URL — used to build the login link in credential emails.
NEXT_PUBLIC_APP_URL=https://www.aesthetixai.fit
NEXT_PUBLIC_APP_NAME=AesthetixAI

# --- Cron (optional) ---
# Any random string. Vercel sends `Authorization: Bearer <CRON_SECRET>` on cron.
CRON_SECRET=

# --- Email (Resend) — thank-you access + credential emails ---
RESEND_API_KEY=
EMAIL_FROM=AesthetixAI <daya@aesthetixai.fit>
ADMIN_NOTIFY_EMAIL=dhruvsangal1999@gmail.com
