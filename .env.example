# --- Supabase (DB + Auth + Storage) ---
# Project URL and anon key from Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for Drizzle migrations.
# Supabase dashboard > Project Settings > Database > Connection string (URI, "Session" pooler)
DATABASE_URL=

# Storage bucket name — create a bucket called "physique-photos" in Supabase Storage (private).
SUPABASE_PHOTO_BUCKET=physique-photos

# --- AI provider (Anthropic Claude) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional model override. Default is the latest vision-capable Claude.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FitCoach

# --- Stripe (subscription-ready, optional for MVP) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_LIFETIME=

# --- Email (optional) ---
RESEND_API_KEY=
