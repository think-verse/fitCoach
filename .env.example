# --- Supabase (DB + Auth + Storage) ---
# Project URL and anon key from Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for Drizzle migrations.
# Supabase dashboard > Project Settings > Database > Connection string (URI, "Session" pooler)
DATABASE_URL=

# Storage bucket name — create a bucket called "physique-photos" in Supabase Storage (private).
SUPABASE_PHOTO_BUCKET=physique-photos

# --- AI provider (Anthropic Claude) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Hybrid model tiers (cost optimization):
#   VISION_MODEL — photo body analysis + weekly photo comparison (quality-critical)
#   TEXT_MODEL   — workout / diet / coach chat (cheaper, text-only)
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_TEXT_MODEL=claude-haiku-4-5

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FitCoach

# --- Stripe (subscription-ready, optional for MVP) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_LIFETIME=

# --- Email (optional) ---
RESEND_API_KEY=

# --- systeme.io purchase webhook ---
# Any random string. Configure in systeme.io as an "X-Webhook-Secret" header
# on the automation that calls POST /api/webhooks/systemeio. Leave blank to
# disable the secret check (NOT recommended in production).
SYSTEMEIO_WEBHOOK_SECRET=

# --- Cron auth (optional but recommended) ---
# Any random string. Vercel auto-sends `Authorization: Bearer <CRON_SECRET>`
# on every cron invocation; /api/cron/ping verifies it. Leave blank in dev.
CRON_SECRET=
